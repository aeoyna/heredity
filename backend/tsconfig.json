{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "node",
    "lib": ["es2022"],
    "strict": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "types": ["@cloudflare/workers-types", "node"],
    "outDir": "./dist",
    "skipLibCheck": true
  },
  "include": ["src/**/*", "db/**/*"]
}
